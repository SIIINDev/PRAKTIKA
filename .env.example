# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=kb
POSTGRES_PASSWORD=kb_password_change_me
POSTGRES_DB=knowledge_base
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=documents

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SEARCH_CACHE_TTL=300

# ── Backend app ──────────────────────────────────────────────
APP_ENV=production
MAX_UPLOAD_MB=20
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
UPLOAD_DIR=/data/uploads
LOG_LEVEL=INFO

# ── Frontend (build-time) ────────────────────────────────────
# In docker-compose the frontend is served by nginx which proxies /api to the backend,
# so the browser calls the same origin. For local `npm run dev` Vite proxies /api.
VITE_API_BASE=/api/v1

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Published host ports (change if a port is already in use) ─
APP_PORT=8000
FRONT_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
